<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:text="In‑App Voice"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvChannel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvTitle"
        android:layout_marginTop="10dp"
        android:text="Channel:"
        android:textColor="#AAAAAA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvChannel"
        android:layout_marginTop="6dp"
        android:text="Listening"
        android:textColor="#4CAF50"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvStatus"
        android:layout_marginTop="6dp"
        android:text="Mode:"
        android:textColor="#AAAAAA"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnRelaySettings"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_below="@+id/tvMode"
        android:layout_marginTop="10dp"
        android:backgroundTint="#333333"
        android:text="RELAY SETTINGS"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnTalk"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_centerInParent="true"
        android:backgroundTint="@android:color/holo_green_dark"
        android:text="TAP TO TALK"
        android:textAllCaps="true"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="22sp" />

    <Button
        android:id="@+id/btnEndCall"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:backgroundTint="#D32F2F"
        android:text="END WALKIE-TALKIE"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="18sp" />

</RelativeLayout>
