<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#000000">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Internet Relay"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Enable this to talk from any distance (Wi‑Fi/4G/5G). You must run your own relay server."
        android:textColor="#AAAAAA"
        android:textSize="13sp" />

    <EditText
        android:id="@+id/etRelayHost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:hint="Relay host (IP/domain)"
        android:inputType="textUri"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:backgroundTint="#4CAF50" />

    <EditText
        android:id="@+id/etRelayPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Relay port (e.g. 50555)"
        android:inputType="number"
        android:textColor="#FFFFFF"
        android:textColorHint="#666666"
        android:backgroundTint="#4CAF50" />

    <Button
        android:id="@+id/btnSaveRelay"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="18dp"
        android:text="SAVE &amp; ENABLE"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="@android:color/holo_green_dark" />

    <Button
        android:id="@+id/btnDisableRelay"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="10dp"
        android:text="DISABLE (LAN ONLY)"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#444444" />

</LinearLayout>
